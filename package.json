{
  "name": "safepaste",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix packages/api",
    "start": "node packages/api/server.js",
    "test": "node packages/core/test.js && node packages/test/test.js && node packages/guard/test.js && node packages/api/test.js",
    "test:core": "node packages/core/test.js",
    "test:test": "node packages/test/test.js",
    "test:guard": "node packages/guard/test.js",
    "test:api": "node packages/api/test.js",
    "build:extension": "node scripts/build-extension.js",
    "migrate": "node packages/api/db.js",
    "validate:dataset": "node scripts/dataset/validate.js datasets/prompt-injection/",
    "evaluate:dataset": "node scripts/dataset/evaluate.js datasets/prompt-injection/",
    "stats:dataset": "node scripts/dataset/stats.js datasets/prompt-injection/",
    "view:dataset": "node scripts/dataset/view.js datasets/prompt-injection/curated/",
    "diagnose:dataset": "node scripts/dataset/diagnose.js datasets/prompt-injection/curated/",
    "mutate:dataset": "node scripts/dataset/mutate.js",
    "merge:dataset": "node scripts/dataset/merge.js",
    "version:dataset": "node scripts/dataset/version.js"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}